{
  "manifest_version": 3,
  "name": "Codex Rollout Viewer",
  "short_name": "Rollout Viewer",
  "version": "0.1.0",
  "description": "Render local Codex rollout JSONL files as a compact dark-mode HTML viewer.",
  "content_scripts": [
    {
      "matches": ["file:///*"],
      "js": ["content-loader.js"]
    }
  ],
  "web_accessible_resources": [
    {
      "matches": ["file:///*"],
      "resources": [
        "rollout-renderer.js",
        "vendor/highlightjs/*"
      ]
    }
  ]
}
